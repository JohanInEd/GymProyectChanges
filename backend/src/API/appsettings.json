{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=GymSaaS;Username=postgres"
  },
  "Postgres": {
    "EnableSensitiveDataLogging": false,
    "CommandTimeoutSeconds": 30
  },
  "Jwt": {
    "Issuer": "GymSaaS.Api",
    "Audience": "GymSaaS.Client",
    "SigningKey": "REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS_LONG",
    "ExpiryMinutes": 720
  },
  "Billing": {
    "GraceDays": 1,
    "EnforceSubscription": true
  },
  "Cors": {
    "AllowedOrigins": ["https://gymassist.online"]
  },
  "Frontend": {
    "BaseUrl": "https://gymassist.online"
  }
}
